{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ProducerSendMessages",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage",
        "sqs:GetQueueUrl"
      ],
      "Resource": [
        "arn:aws:sqs:eu-central-1:054862141870:cn-course-product-events"
      ]
    },
    {
      "Sid": "ConsumerReceiveAndDelete",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": [
        "arn:aws:sqs:eu-central-1:054862141870:cn-course-product-events",
        "arn:aws:sqs:eu-central-1:054862141870:cn-course-product-events-dlq"
      ]
    }
  ]
}
